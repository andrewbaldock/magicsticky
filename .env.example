# magicsticky Phase 2 — copy to .env and fill in. .env is gitignored.

# SQLite store path. Local: a file in the repo (gitignored). On Fly: the mounted volume path.
MAGICSTICKY_DB=./magicsticky.db

# The static bearer token the Claude connector authenticates with (single-user MVP). Generate a
# long random string, e.g.  openssl rand -hex 32  — keep this one SECRET (it guards your data).
MAGICSTICKY_TOKEN=

# App-layer encryption keys for sticky text at rest, as "id:hexkey,id2:hexkey2" (FIRST = primary,
# used for new writes; others kept for decrypting/rotating old rows). Each key = 32 bytes hex,
# e.g.  echo "v1:$(openssl rand -hex 32)"  — keep SECRET. Unset → text stored as plaintext (dev).
MAGICSTICKY_KEYS=

# The userId that token maps to (single-user MVP).
MAGICSTICKY_USER=andrew

# HTTP listen port.
PORT=3000

# Google OAuth client ID for human sign-in (GIS token flow). PUBLIC — ships in the browser.
# When unset, /auth/google returns 501 (sign-in disabled).
GOOGLE_CLIENT_ID=91567435125-jr7t0tds56jg684ebl9pensj1ti3kgka.apps.googleusercontent.com

# WHO may sign in (comma-separated). Without an allowlist, sign-in is deny-all (403) — this is what
# keeps the single-user/demo app from minting accounts for any Google user. Set at least one.
# By Google account id (the OIDC 'sub'):
MAGICSTICKY_ALLOWED_SUBS=
# ...and/or by verified email (easier to read). Add a guest's email here to let them try it:
MAGICSTICKY_ALLOWED_EMAILS=andrewbaldock3@gmail.com

# Secret for signing the human web session cookie (HMAC). Generate: openssl rand -hex 32 — SECRET.
# Required for web sign-in / the /api routes; rotating it logs everyone out.
MAGICSTICKY_SESSION_SECRET=
