{
  "name": "magicsticky",
  "version": "0.1.0",
  "description": "Hosted sticky notes where one note is the shared prompt any Claude reads/writes over MCP",
  "license": "AGPL-3.0",
  "type": "module",
  "bin": {
    "magicsticky": "./src/server-http.ts"
  },
  "scripts": {
    "start": "bun run src/server-http.ts",
    "dev:web": "vite",
    "build:web": "vite build",
    "test": "bun test test/",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web/tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dompurify": "^3.4.11",
    "hono": "^4.12.25",
    "jose": "^6.2.3",
    "lucide-react": "^1.20.0",
    "marked": "^18.0.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.7.0",
    "vite": "^8.0.16"
  }
}
